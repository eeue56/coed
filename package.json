{
    "name": "@eeue56/coed",
    "version": "1.0.0-1",
    "description": "Write HTML in pure TS",
    "main": "build/coed.js",
    "type": "module",
    "files": [
        "./build/coed.js",
        "./build/coed.d.ts",
        "./build/svg.js",
        "./build/svg.d.ts",
        "./build/parse.js",
        "./build/parse.d.ts",
        "./build/types.d.ts",
        "./build/types.js"
    ],
    "exports": {
        ".": {
            "types": "./build/coed.d.ts",
            "import": "./build/coed.js",
            "default": "./build/coed.js"
        },
        "./svg": {
            "types": "./build/svg.d.ts",
            "import": "./build/svg.js",
            "default": "./build/svg.js"
        },
        "./parse": {
            "types": "./build/parse.d.ts",
            "import": "./build/parse.js",
            "default": "./build/parse.js"
        },
        "./types": {
            "types": "./build/types.d.ts",
            "import": "./build/types.js",
            "default": "./build/types.js"
        }
    },
    "typings": "build/coed.d.ts",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "watch": "tsc -w -p tsconfig.json",
        "format": "npx prettier --write .",
        "test": "npx @eeue56/bach",
        "docs": "npx @eeue56/geiriadur"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eeue56/coed.git"
    },
    "keywords": [
        "typescript",
        "elm",
        "html",
        "hiraeth"
    ],
    "author": "eeue56",
    "license": "BSD-3-Clause",
    "bugs": {
        "url": "https://github.com/eeue56/coed/issues"
    },
    "homepage": "https://github.com/eeue56/coed#readme",
    "devDependencies": {
        "@eeue56/bach": "^1.0.1",
        "@eeue56/geiriadur": "^0.0.3",
        "@types/jsdom": "^28.0.3",
        "@types/node": "^24.0.3",
        "typescript": "^6.0.3",
        "jsdom": "^29.1.1"
    }
}
